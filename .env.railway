# ─────────────────────────────────────────────────────────────────────────────
# Pe — Railway Environment Variables Template
# Copy the relevant section into each Railway service's "Variables" tab.
# Variables marked (auto) are injected automatically by Railway plugins.
# ─────────────────────────────────────────────────────────────────────────────

# ── API Service ───────────────────────────────────────────────────────────────
NODE_ENV=production
DATABASE_URL=                          # (auto) from Postgres plugin
REDIS_URL=                             # (auto) from Redis plugin
ANTHROPIC_API_KEY=sk-ant-...           # Required for AI validation
VALIDATOR_SERVICE_URL=http://validator.railway.internal:3010
PA_SIMULATOR_SERVICE_URL=http://pa-simulator.railway.internal:3003
CORS_ORIGINS=https://REPLACE_WITH_DASHBOARD_URL.up.railway.app
# Optional billing
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_STARTER=price_...
STRIPE_PRICE_ID_GROWTH=price_...

# ── Dashboard Service ─────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_API_URL=https://REPLACE_WITH_API_URL.up.railway.app

# ── PA Simulator Service ──────────────────────────────────────────────────────
NODE_ENV=production
DATABASE_URL=                          # (auto) from Postgres plugin
REDIS_URL=                             # (auto) from Redis plugin

# ── Validator Service ─────────────────────────────────────────────────────────
NODE_ENV=production
ANTHROPIC_API_KEY=sk-ant-...           # Required for AI error enrichment
