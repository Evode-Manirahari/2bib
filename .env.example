# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://pe:pe_password@localhost:5432/pe_dev"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── HAPI FHIR Server ──────────────────────────────────────────────────────────
HAPI_FHIR_URL="http://localhost:8080/fhir"

# ── Service Ports ─────────────────────────────────────────────────────────────
API_PORT=3001
PROXY_PORT=3002
VALIDATOR_PORT=3010
PA_SIMULATOR_PORT=3003

# ── API Gateway ───────────────────────────────────────────────────────────────
# Internal service URLs (used by api gateway to proxy to other services)
PROXY_SERVICE_URL="http://localhost:3002"
VALIDATOR_SERVICE_URL="http://localhost:3010"
PA_SIMULATOR_SERVICE_URL="http://localhost:3003"

# CORS allowed origins (comma-separated)
CORS_ORIGINS="http://localhost:3000"

# ── AI Layer ──────────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
# Get your keys at https://dashboard.clerk.com
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."

# ── Billing (Stripe) ──────────────────────────────────────────────────────────
# Get your keys at https://dashboard.stripe.com
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID_STARTER="price_..."
STRIPE_PRICE_ID_GROWTH="price_..."

# ── Monitoring ────────────────────────────────────────────────────────────────
# Sentry — https://sentry.io
SENTRY_DSN=""
# PostHog — https://posthog.com
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ── Dashboard ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"

# ── Docker Compose (production) ───────────────────────────────────────────────
# Used by docker-compose.prod.yml
REGISTRY=ghcr.io
IMAGE_REPO=your-org/pe
IMAGE_TAG=latest
POSTGRES_DB=pe
POSTGRES_USER=pe
POSTGRES_PASSWORD=change_me_in_production

# ── Node env ──────────────────────────────────────────────────────────────────
NODE_ENV="development"
